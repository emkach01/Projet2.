<h2>🌤️ Météo</h2>

@if (ViewBag.Weather != null && ViewBag.Weather.Main != null)
{
    <div style="border:1px solid #ccc; padding:15px; border-radius:10px; width:300px;">

        <h3>@ViewBag.Weather.Name</h3>

        <p><strong>🌡️ Température :</strong> @ViewBag.Weather.Main.Temp °C</p>

        <p><strong>🤔 Ressenti :</strong> @ViewBag.Weather.Main.Feels_Like °C</p>

        <p><strong>💧 Humidité :</strong> @ViewBag.Weather.Main.Humidity %</p>

        <p><strong>🌥️ Description :</strong> @ViewBag.Weather.Weather?[0]?.Description</p>

        <p><strong>🌬️ Vent :</strong> @ViewBag.Weather.Wind?.Speed m/s</p>

    </div>
}
else
{
    <p>❌ Impossible de charger la météo</p>
}

<h2>🎬 Films populaires</h2>

@if (ViewBag.Movies?.Results != null)
{
    <div style="display:flex; flex-wrap:wrap; gap:20px;">
        @foreach (var movie in ViewBag.Movies.Results)
        {
            <div style="width:200px;">
                <h4>@movie.Title</h4>

                <img src="https://image.tmdb.org/t/p/w200/@movie.PosterPath"
                     style="width:100%; border-radius:10px;" />
            </div>
        }
    </div>
}